{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "env": {
    "NODE_ENV": "production",
    "USE_SUPABASE_DB": "true",
    "PUBLIC_URL": "https://nova-nine-rust.vercel.app",
    "CORS_ORIGINS": "https://nova-nine-rust.vercel.app",
    "ADMIN_EMAIL": "admin@nova.com",
    "ADMIN_PASSWORD": "NovaAdmin2026!",
    "JWT_SECRET": "nova-prod-jwt-7f3a9b2c1d4e6f8a0b2c4d6e8f0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/help", "destination": "/help.html" },
    { "source": "/auth/callback", "destination": "/index.html" }
  ]
}
