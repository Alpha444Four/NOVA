PORT=3000
NODE_ENV=development

# Public URL the app is reachable at (used for docs / deployment).
# In production this should match the domain you point to your host.
PUBLIC_URL=https://novadeluxe.dpdns.org

# Session cookie `Secure` flag. Auto: secure only when NODE_ENV=production AND
# PUBLIC_URL is https. Set COOKIE_SECURE=false for local HTTP dev if needed.
# COOKIE_SECURE=false

# Generate a long random string (32+ chars) — required in production
JWT_SECRET=use-a-long-random-string-at-least-32-characters

# Admin login (change these before going live!)
ADMIN_EMAIL=admin@nova.com
ADMIN_PASSWORD=NovaAdmin2026!

# CORS — comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://novadeluxe.dpdns.org,http://novadeluxe.dpdns.org

# ────────────────────────────────────────────────────────────────────
# Supabase — Google & Apple sign-in (see OAUTH_SETUP.md)
# Project Settings → API: copy URL + anon + service_role keys.
# Also copy URL + anon into client/.env as VITE_SUPABASE_* then npm run build.
# Leave blank to use password-only auth.
# ────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres (Settings → Database → Connection string → Transaction pooler)
# Run supabase/migrations/*.sql + seed.sql in SQL Editor first.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.uifabtkdvfmlmprxvklm.supabase.co:5432/postgres
# Set true only when DATABASE_URL is a real Supabase Postgres URI (not the placeholder).
USE_SUPABASE_DB=false
